# Efimeramente Panel de Control — environment variables
# Copy this file to `.env` and fill in the anon key.
# The app runs on realistic DEMO data until both values are present;
# it switches to live Supabase automatically once the key is set.

VITE_SUPABASE_URL=https://vnityzpuhnkumsyfnskz.supabase.co
VITE_SUPABASE_ANON_KEY=

